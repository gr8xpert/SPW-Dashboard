APP_NAME="Smart Property Widget"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://smartpropertywidget.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smartpropertywidget
DB_USERNAME=spw_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=30

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@smartpropertywidget.com"
MAIL_FROM_NAME="${APP_NAME}"

# Paddle — Widget (Sister Company: subscriptions, renewals, expiry)
PADDLE_WIDGET_VENDOR_ID=
PADDLE_WIDGET_API_KEY=
PADDLE_WIDGET_WEBHOOK_SECRET=
PADDLE_WIDGET_SANDBOX=true

# Paddle — Platform (Parent Company: credit hours, mailer packages)
PADDLE_PLATFORM_VENDOR_ID=
PADDLE_PLATFORM_API_KEY=
PADDLE_PLATFORM_WEBHOOK_SECRET=
PADDLE_PLATFORM_SANDBOX=true

# Paddle Credit Pack Price IDs (from Platform account)
PADDLE_CREDIT_PRICE_5H=
PADDLE_CREDIT_PRICE_10H=
PADDLE_CREDIT_PRICE_20H=

# Claude API (AI Template Generation + AI Property Search)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenRouter API (Widget AI Search)
OPENROUTER_API_KEY=

# Unlayer WYSIWYG Editor
UNLAYER_PROJECT_ID=

# Platform SMTP (shared sending pool)
PLATFORM_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USERNAME=
PLATFORM_SMTP_PASSWORD=

# Tracking domain
TRACKING_DOMAIN=https://track.smartpropertywidget.com

# Separate encryption key for SMTP passwords
SMTP_ENCRYPTION_KEY=

# n8n Integration
N8N_WEBHOOK_BASE_URL=https://n8n.smartpropertywidget.com
N8N_API_KEY=

# Unsplash (stock photos)
UNSPLASH_ACCESS_KEY=

# Internal API key (for n8n → Laravel, widget proxy → Laravel)
INTERNAL_API_KEY=

# Widget proxy base URL (where the widget PHP proxy is served from)
WIDGET_PROXY_URL=https://smartpropertywidget.com/spw/dist

# Widget analytics API (RealtysoftV3 PHP analytics endpoint)
WIDGET_ANALYTICS_URL=https://smartpropertywidget.com/spw/php/analytics-api.php

VITE_APP_NAME="${APP_NAME}"
